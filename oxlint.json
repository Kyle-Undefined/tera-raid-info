{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "nursery": "off",
    "style": "off",
    "restriction": "off"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/no-unused-vars": "warn"
  },
  "ignore_patterns": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "projects/**"
  ]
}
